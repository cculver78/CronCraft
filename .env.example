GIT_CLONE_TOKEN=your_github_token_here
SECRET_KEY=your-secret-key-here
FLASK_APP=run.py
FLASK_DEBUG=1
DATABASE_URL=mysql+pymysql://croncraft:your_password@localhost/croncraft

# Self-hosted mode: set to true to unlock all features, skip billing UI, and bypass reCAPTCHA
SELF_HOSTED=true

# Email Configuration
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=noreply@example.com


# Stripe Config (OPTIONAL — omit all for self-hosted mode with all features unlocked)
# STRIPE_SECRET_KEY=sk_live_your_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# STRIPE_PRO_PRICE_ID=price_your_pro_id
# STRIPE_TEAM_PRICE_ID=price_your_team_id
